        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(execution_engine_claim_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
